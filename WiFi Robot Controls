void sendOk(WiFiClient& client, const char* text = "OK") {
client.println("HTTP/1.1 200 OK");
client.println("Content-Type: text/plain");
client.println("Connection: close");
client.println();
client.println(text);
}

// -------------------- REQUEST HANDLING --------------------

void handleGetRequest(const String& request, WiFiClient& client) {
if (request.indexOf("GET /cmd?move=forward") >= 0) {
setAction("forward");
sendOk(client);
}
else if (request.indexOf("GET /cmd?move=reverse") >= 0) {
setAction("reverse");
sendOk(client);
}
else if (request.indexOf("GET /cmd?move=left") >= 0) {
setAction("left");
sendOk(client);
}
else if (request.indexOf("GET /cmd?move=right") >= 0) {
setAction("right");
sendOk(client);
}
else if (request.indexOf("GET /cmd?move=strafeleft") >= 0) {
setAction("strafeleft");
sendOk(client);
}
else if (request.indexOf("GET /cmd?move=straferight") >= 0) {
setAction("straferight");
sendOk(client);
}
else if (request.indexOf("GET /cmd?move=stop") >= 0) {
setAction("stop");
sendOk(client);
}
else {
sendPage(client);
}
}

void handlePostRunRequest(const String& request, WiFiClient& client) {
int bodyIndex = request.indexOf("\r\n\r\n");
if (bodyIndex < 0) {
sendOk(client, "NO BODY");
return;
}

String body = request.substring(bodyIndex + 4);
body = urlDecode(body);

sendOk(client, "RUNNING");
runCommandList(body);
}

// -------------------- SETUP --------------------

void setup() {
Serial.begin(9600);
robot.begin();
robot.stop();

Serial.println("Starting Access Point...");
int status = WiFi.beginAP(ssid, pass);

if (status != WL_AP_LISTENING) {
Serial.println("Failed to start AP");
while (true) {
}
}

server.begin();

Serial.println("Access Point started");
Serial.print("SSID: ");
Serial.println(ssid);
Serial.print("Password: ");
Serial.println(pass);
Serial.print("Open: http://");
Serial.println(WiFi.localIP());
}

// -------------------- LOOP --------------------

void loop() {
WiFiClient client = server.available();
if (!client) return;

String request = "";
unsigned long startTime = millis();

while (client.connected() && millis() - startTime < 2000) {
while (client.available()) {
char c = client.read();
request += c;
}

if (request.indexOf("\r\n\r\n") >= 0) {
// For POST, wait briefly for more body data
if (request.startsWith("POST /run")) {
delay(50);
while (client.available()) {
request += (char)client.read();
}
}

if (request.startsWith("POST /run")) {
handlePostRunRequest(request, client);
} else {
handleGetRequest(request, client);
}

client.stop();
return;
}
}

client.stop();
}
