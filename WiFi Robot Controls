#include <WiFiS3.h>
#include <MecanumRobot.h>

char ssid[] = "BOT#";  //Change to a different number, if using a school laptop, use that number.
char pass[] = "12345678";

//connect to the Arduino board wifi, the bot name will be BOT#(whatever number you assigned it)
//then open a browser and type in 192.168.1

WiFiServer server(80);
MecanumRobot robot(4, 3, 6, 5, 10, 9, 12, 11);

String currentAction = "stop";

// -------------------- ACTION CONTROL --------------------

void setAction(const String& action) {
currentAction = action;

if (action == "forward") {
robot.forwardStart();
delay(500);         // move for 500ms
robot.stop();       // stop automatically

}
else if (action == "reverse") {
robot.reverseStart();
delay(500);         // move for 500ms
robot.stop();       // stop automatically
}
else if (action == "left") {
robot.turnLeftStart();
delay(640);         // move for 500ms
robot.stop();       // stop automatically
}
else if (action == "right") {
robot.turnRightStart();
delay(640);         // move for 500ms
robot.stop();       // stop automatically

}
else if (action == "strafeleft") {
robot.strafeLeftStart();
delay(500);         // move for 500ms
robot.stop();       // stop automatically
}
else if (action == "straferight") {
robot.strafeRightStart();
delay(500);         // move for 500ms
robot.stop();       // stop automatically
}
else {
robot.stop();
currentAction = "stop";
}
}

// -------------------- COMMAND EXECUTION --------------------

void runCommandLine(String line) {
line.trim();
if (line.length() == 0) return;

int spaceIndex = line.indexOf(' ');
String command;
int value = 0;

if (spaceIndex > 0) {
command = line.substring(0, spaceIndex);
value = line.substring(spaceIndex + 1).toInt();
} else {
command = line;
}

command.toLowerCase();

if (command == "forward") {
robot.forward(value);
}
else if (command == "reverse") {
robot.reverse(value);
}
else if (command == "left") {
robot.left(value);
}
else if (command == "right") {
robot.right(value);
}
else if (command == "strafeleft") {
robot.strafeLeft(value);
}
else if (command == "straferight") {
robot.strafeRight(value);
}
else if (command == "pause") {
delay(value);
}
else if (command == "stop") {
robot.stop();
}
}

void runCommandList(String commands) {
robot.stop();
currentAction = "script";

int start = 0;
while (start < commands.length()) {
int endIndex = commands.indexOf('\n', start);
if (endIndex == -1) {
endIndex = commands.length();
}

String line = commands.substring(start, endIndex);
runCommandLine(line);

start = endIndex + 1;
}

robot.stop();
currentAction = "stop";
}

// -------------------- URL DECODE --------------------

String urlDecode(String input) {
String output = "";
char temp[] = "0x00";

for (unsigned int i = 0; i < input.length(); i++) {
char c = input.charAt(i);

if (c == '+') {
output += ' ';
}
else if (c == '%' && i + 2 < input.length()) {
temp[2] = input.charAt(i + 1);
temp[3] = input.charAt(i + 2);
output += (char) strtol(temp, NULL, 16);
i += 2;
}
else {
output += c;
}
}

return output;
}

